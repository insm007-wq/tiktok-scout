# MongoDB
MONGODB_URI=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Resend (이메일 발송)
RESEND_API_KEY=re_xxxxxxxxxxxx
# 발신 이메일 주소 (반드시 Resend에 등록/인증된 도메인)
# 예: no-reply@your-domain.com
EMAIL_FROM=no-reply@your-domain.com

# 토스페이먼츠 (Toss Payments)
# 개발: https://developers.tosspayments.com/ 에서 테스트 키 발급
# 운영: 토스페이먼츠 가맹점 등록 후 라이브 키로 교체
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_CLIENT_SECRET=test_sk_xxxx

# 자동결제 크론 시크릿 (서버 crontab에서 x-cron-secret 헤더로 전달)
CRON_SECRET=랜덤_긴_문자열_여기에_입력
