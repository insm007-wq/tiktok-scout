# MongoDB
MONGODB_URI=

# NextAuth (Auth.js v5)
# Vercel: Settings → Environment Variables 에서 Production에 설정
# - AUTH_URL: 실제 접속 URL (예: https://tiktalk-killa.com)
# - AUTH_TRUST_HOST=true (리다이렉트 루프 방지)
AUTH_SECRET=
AUTH_URL=
AUTH_TRUST_HOST=true
# 레거시 호환 (선택)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Resend (이메일 발송)
RESEND_API_KEY=re_xxxxxxxxxxxx
# 발신 이메일 주소 (반드시 Resend에 등록/인증된 도메인)
# 예: no-reply@your-domain.com
EMAIL_FROM=no-reply@your-domain.com

# 토스페이먼츠 (Toss Payments)
# 개발: https://developers.tosspayments.com/ 에서 테스트 키 발급
# 운영: 토스페이먼츠 가맹점 등록 후 라이브 키로 교체
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_CLIENT_SECRET=test_sk_xxxx

# 자동결제 크론 시크릿 (서버 crontab에서 x-cron-secret 헤더로 전달)
CRON_SECRET=랜덤_긴_문자열_여기에_입력

# 로컬 큐(검색 워커) - Redis + Apify
# REDIS_URL 없으면 기본값 redis://localhost:6379 (로컬 Redis 또는 npm run redis:local)
REDIS_URL=redis://localhost:6379
APIFY_API_KEY=apify_api_xxxx
