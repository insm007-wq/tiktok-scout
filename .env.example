# ====== 기본 설정 ======
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# ====== Redis (BullMQ 큐) ======
# 개발용 (.env.local): 상용 Redis 사용 금지.
#   - 로컬 Redis: redis://localhost:6379 (npm run redis:local)
#   - tiktok-scout Copy 워커 연동: Copy 프로젝트 REDIS_URL 복사
# 배포용 (Vercel/Railway): 상용 전용 Redis URL을 환경변수로 설정
REDIS_URL=redis://localhost:6379

# ====== MongoDB ======
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ====== Apify ======
APIFY_API_KEY=your-apify-key-here
# 샤오홍슈 검색 액터: kuaima(기본) | easyapi 로 바꾸려면 아래 주석 해제
# XIAOHONGSHU_SEARCH_ACTOR=easyapi

# ====== Railway 스크래퍼 ======
RAILWAY_SERVER_URL=https://your-railway-scraper-url.up.railway.app
RAILWAY_API_SECRET=your-railway-api-secret

# ====== Invitation Code ======
# Required code for user signup. Users with valid code get auto-approved.
# Code is case-insensitive.
INVITATION_CODE=YOUR_INVITATION_CODE_HERE

# ====== Worker 설정 ======
# 로컬: npm run worker:dev (큐 video-search-dev, 동시성 기본 2) / 배포: npm run worker (큐 video-search)
WORKER_CONCURRENCY=50
# 큐 이름 오버라이드 (미설정 시 production=video-search, development=video-search-dev)
# QUEUE_NAME=video-search

# ====== Socket.io ======
SOCKETIO_PATH=/api/socketio

# ====== OpenAI API (Whisper 자막 추출용) ======
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====== 자동 재크롤링 설정 (CDN URL 만료 시) ======
# 자동 재크롤링 활성화/비활성화
RECRAWL_ENABLE_AUTO=true
# 시간당 재크롤링 최대 횟수 (중복 방지) - 프론트엔드에서 5분 cooldown도 추가됨
RECRAWL_RATE_LIMIT_PER_HOUR=100
# 재크롤링 최대 시도 횟수
RECRAWL_MAX_ATTEMPTS=3
